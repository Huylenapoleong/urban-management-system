{
  "name": "urban-management-system",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "postinstall": "node scripts/patch-nestjs-swagger.mjs",
    "dev:admin": "pnpm --filter admin-web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:mobile": "pnpm --filter mobile-app start",
    "dev:flutter": "pnpm --filter mobile-app-fluter start",
    "dev:flutter:mobile": "pnpm --filter mobile-app-fluter start:mobile",
    "dev:web": "pnpm --filter web-app dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "dependencies": {
    "expo": "^55.0.8",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "version": "1.0.0"
}
