{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@urban/shared-constants": ["../../packages/shared-constants"],
      "@urban/shared-types": ["../../packages/shared-types"],
      "@urban/shared-utils": ["../../packages/shared-utils"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "dist",
    "build"
  ]
}
