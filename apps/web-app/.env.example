# API Base URL (Backend chạy ở port 3001 mặc định)
VITE_API_URL=http://localhost:3001/api

# Socket URL (Thường giống với API URL nhưng bỏ /api)
VITE_SOCKET_URL=http://localhost:3001

# TURN server credentials (Metered.ca) — bắt buộc cho mạng corporate/symmetric NAT
# Nếu bỏ trống, WebRTC chỉ dùng STUN (có thể fail khi web gọi cho mobile qua NAT đối xứng)
# Đăng ký tại: https://dashboard.metered.ca/
VITE_TURN_USERNAME=
VITE_TURN_PASSWORD=
